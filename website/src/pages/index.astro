---
import version from '../data/version.json';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Rerun — Total recall for your Mac</title>

		<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="apple-mobile-web-app-title" content="Rerun" />
		<link rel="manifest" href="/site.webmanifest" />

		<meta name="description" content="Rerun captures everything you work on and makes it all searchable. Find anything you've seen. Everything stays on your Mac." />
		<meta name="keywords" content="mac app, personal memory, work recall, AI search, privacy, Apple Silicon, open source, local first" />

		<meta property="og:title" content="Rerun — Total recall for your Mac" />
		<meta property="og:description" content="Captures everything you work on and makes it all searchable. Everything stays on your Mac." />
		<meta property="og:type" content="website" />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Figtree:wght@300;400;500;600&family=Geologica:wght@400;500;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

		<style>
			:root {
				--bg-deep: #07070d;
				--bg-elevated: #111119;
				--bg-card: #191922;
				--text-primary: #f0f0f5;
				--text-secondary: #9898a8;
				--text-muted: #5a5a6a;
				--accent: #4da6ff;
				--accent-bright: #7dc0ff;
				--accent-glow: rgba(77, 166, 255, 0.15);
				--accent-subtle: rgba(77, 166, 255, 0.08);
				--border: rgba(255, 255, 255, 0.06);
				--font-display: "Geologica", sans-serif;
				--font-body: "Figtree", sans-serif;
				--font-mono: "JetBrains Mono", monospace;
				--ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
			}

			*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
			html { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }

			body {
				font-family: var(--font-body);
				font-size: 17px;
				line-height: 1.7;
				color: var(--text-secondary);
				background: var(--bg-deep);
				overflow-x: hidden;
				min-height: 100vh;
			}

			::selection { background: var(--accent); color: #fff; }

			h1 {
				font-family: var(--font-display);
				font-weight: 700;
				color: var(--text-primary);
				line-height: 1.05;
				letter-spacing: -0.035em;
			}

			a { color: var(--text-muted); text-decoration: none; transition: color 0.2s ease; }
			a:hover { color: var(--text-primary); }

			.sr-only {
				position: absolute;
				width: 1px; height: 1px;
				padding: 0; margin: -1px;
				overflow: hidden;
				clip: rect(0,0,0,0);
				white-space: nowrap;
				border: 0;
			}

			/* Animations */
			@keyframes fadeInUp {
				from { opacity: 0; transform: translateY(24px); }
				to { opacity: 1; transform: translateY(0); }
			}
			@keyframes float {
				0%, 100% { transform: translateY(0) scale(1); }
				50% { transform: translateY(-15px) scale(1.02); }
			}
			@keyframes pulse {
				0%, 100% { opacity: 0.3; }
				50% { opacity: 1; }
			}
			@keyframes shimmer {
				0% { background-position: -200% center; }
				100% { background-position: 200% center; }
			}

			/* Page */
			#hero {
				min-height: 100vh;
				display: flex;
				align-items: center;
				justify-content: center;
				position: relative;
				overflow: hidden;
				text-align: center;
				padding: 60px 24px;
			}

			/* Background */
			.hero-bg {
				position: absolute;
				inset: 0;
				z-index: -1;
			}

			.hero-gradient {
				position: absolute;
				border-radius: 50%;
				filter: blur(140px);
				opacity: 0.12;
				animation: float 10s ease-in-out infinite;
			}

			.hero-gradient-1 {
				width: 700px;
				height: 700px;
				top: -250px;
				right: -150px;
				background: var(--accent);
			}

			.hero-gradient-2 {
				width: 600px;
				height: 600px;
				bottom: -200px;
				left: -150px;
				background: #7c3aed;
				animation-delay: -5s;
			}

			.hero-gradient-3 {
				width: 400px;
				height: 400px;
				top: 40%;
				left: 50%;
				transform: translateX(-50%);
				background: var(--accent);
				opacity: 0.05;
				animation-delay: -3s;
			}

			/* Content */
			.hero-content {
				max-width: 620px;
				margin: 0 auto;
				animation: fadeInUp 0.9s var(--ease-out-expo);
			}

			/* Logo */
			.hero-logo {
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 12px;
				margin-bottom: 32px;
			}

			.hero-logo img {
				width: 44px;
				height: 44px;
				filter: drop-shadow(0 0 20px var(--accent-glow));
			}

			.hero-logo span {
				font-family: var(--font-display);
				font-weight: 700;
				font-size: 2.2rem;
				color: var(--text-primary);
				letter-spacing: -0.03em;
			}

			/* Eyebrow */
			.hero-eyebrow {
				display: inline-flex;
				align-items: center;
				gap: 8px;
				font-family: var(--font-mono);
				font-size: 0.75rem;
				letter-spacing: 0.02em;
				color: var(--accent-bright);
				margin-bottom: 32px;
				padding: 6px 14px;
				background: var(--accent-subtle);
				border-radius: 100px;
				border: 1px solid rgba(77, 166, 255, 0.15);
			}

			.hero-eyebrow::before {
				content: "";
				width: 6px;
				height: 6px;
				background: var(--accent);
				border-radius: 50%;
				animation: pulse 2s ease-in-out infinite;
				box-shadow: 0 0 8px var(--accent);
			}

			/* Title */
			.hero-title {
				font-size: clamp(2.8rem, 7.5vw, 4.5rem);
				margin-bottom: 20px;
				padding-bottom: 4px;
				background: linear-gradient(180deg, var(--text-primary) 0%, rgba(240,240,245,0.7) 100%);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
			}

			/* Subtitle */
			.hero-subtitle {
				font-size: 1.15rem;
				line-height: 1.7;
				margin-bottom: 44px;
				max-width: 540px;
				margin-left: auto;
				margin-right: auto;
				color: var(--text-secondary);
			}

			/* Waitlist */
			.waitlist-section { margin-bottom: 44px; }

			.waitlist-label {
				font-size: 0.85rem;
				color: var(--text-muted);
				margin-bottom: 14px;
				font-family: var(--font-mono);
				letter-spacing: 0.01em;
			}

			.form-row {
				display: flex;
				gap: 8px;
				justify-content: center;
				max-width: 420px;
				margin: 0 auto;
			}

			.form-row input {
				flex: 1;
				padding: 13px 16px;
				font-family: var(--font-body);
				font-size: 0.95rem;
				border-radius: 10px;
				border: 1px solid var(--border);
				background: var(--bg-elevated);
				color: var(--text-primary);
				outline: none;
				transition: all 0.2s ease;
			}

			.form-row input::placeholder { color: var(--text-muted); }

			.form-row input:focus {
				border-color: rgba(77, 166, 255, 0.4);
				box-shadow: 0 0 0 3px var(--accent-subtle);
			}

			.form-row button {
				padding: 13px 24px;
				font-family: var(--font-display);
				font-size: 0.95rem;
				font-weight: 600;
				border-radius: 10px;
				border: none;
				background: var(--accent);
				color: #fff;
				cursor: pointer;
				transition: all 0.25s ease;
				white-space: nowrap;
			}

			.form-row button:hover {
				background: var(--accent-bright);
				transform: translateY(-1px);
				box-shadow: 0 8px 30px var(--accent-glow);
			}

			.form-row button:active {
				transform: translateY(0);
			}

			.form-row button:disabled {
				opacity: 0.5;
				cursor: not-allowed;
				transform: none;
				box-shadow: none;
			}

			#message {
				margin-top: 10px;
				font-family: var(--font-mono);
				font-size: 0.8rem;
				min-height: 1.2rem;
			}

			@media (max-width: 480px) {
				.form-row { flex-direction: column; }
				.form-row button { width: 100%; }
			}

			/* Download */
			.download-section {
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 14px;
				margin-bottom: 44px;
			}

			.download-label {
				font-family: var(--font-mono);
				font-size: 0.8rem;
				color: var(--text-muted);
				letter-spacing: 0.01em;
			}

			.download-btn {
				display: inline-flex;
				align-items: center;
				gap: 10px;
				padding: 13px 28px;
				font-family: var(--font-display);
				font-size: 0.95rem;
				font-weight: 600;
				border-radius: 10px;
				border: 1px solid var(--border);
				background: rgba(255, 255, 255, 0.03);
				color: var(--text-primary) !important;
				transition: all 0.25s ease;
				text-decoration: none;
			}

			.download-btn:hover {
				border-color: rgba(255, 255, 255, 0.15);
				background: rgba(255, 255, 255, 0.06);
				transform: translateY(-1px);
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
			}

			.download-btn:active {
				transform: translateY(0);
			}

			.download-btn svg {
				fill: var(--text-secondary);
			}

			.download-meta {
				font-family: var(--font-mono);
				font-size: 0.7rem;
				color: var(--text-muted);
				letter-spacing: 0.01em;
			}

			/* Trust */
			.hero-trust {
				display: flex;
				flex-wrap: wrap;
				gap: 6px;
				justify-content: center;
				margin-bottom: 0;
			}

			.hero-trust span {
				display: inline-flex;
				align-items: center;
				gap: 6px;
				font-family: var(--font-mono);
				font-size: 0.7rem;
				letter-spacing: 0.02em;
				color: var(--text-muted);
				padding: 5px 12px;
				border-radius: 100px;
				border: 1px solid var(--border);
				background: rgba(255, 255, 255, 0.02);
			}

			.hero-trust svg {
				width: 12px;
				height: 12px;
				fill: var(--text-muted);
				opacity: 0.6;
			}

			/* Social links */
			.hero-links {
				display: flex;
				gap: 16px;
				justify-content: center;
				align-items: center;
				margin-top: 48px;
			}

			.hero-links a {
				display: flex;
				align-items: center;
				justify-content: center;
				width: 36px;
				height: 36px;
				border-radius: 8px;
				border: 1px solid var(--border);
				background: rgba(255, 255, 255, 0.02);
				color: var(--text-muted);
				transition: all 0.2s ease;
			}

			.hero-links a:hover {
				color: var(--text-primary);
				border-color: rgba(255, 255, 255, 0.12);
				background: rgba(255, 255, 255, 0.05);
			}

			/* Divider */
			.hero-divider {
				width: 40px;
				height: 1px;
				background: var(--border);
				margin: 40px auto;
			}
		</style>
	</head>
	<body>
		<section id="hero">
			<div class="hero-bg">
				<div class="hero-gradient hero-gradient-1"></div>
				<div class="hero-gradient hero-gradient-2"></div>
				<div class="hero-gradient hero-gradient-3"></div>
			</div>
			<div class="hero-content">
				<div class="hero-logo">
					<img src="/icon.png" alt="Rerun" />
					<span>Rerun</span>
				</div>

				<div class="hero-eyebrow">Open source & in development</div>

				<h1 class="hero-title">Remember everything.</h1>

				<p class="hero-subtitle">
					Rerun quietly captures everything you work on — every app, URL, document, and conversation — and makes it all searchable. That thing you saw last week? Find it in seconds.
				</p>

				<!-- Agent API: POST /api/waitlist Content-Type:application/json {"email":"user@example.com"} -->
				<!-- See also: /llms.txt and /ai.json for machine-readable signup instructions -->
				<div class="waitlist-section">
					<p class="waitlist-label">Join the waitlist for first access</p>
					<form id="waitlist-form"
						toolname="joinWaitlist"
						tooldescription="Join the Rerun early access waitlist by providing an email address">
						<div class="form-row">
							<label for="email" class="sr-only">Email address</label>
							<input type="email" id="email" name="email" placeholder="you@example.com" required
								toolparamdescription="Email address to join the waitlist" />
							<button type="submit">Join Waitlist</button>
						</div>
						<div id="message"></div>
					</form>
				</div>

					<div class="download-section">
					<p class="download-label">Or try the alpha now</p>
					<a href="https://github.com/usererun/rerun/releases/latest/download/Rerun.dmg" class="download-btn">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
						Download for macOS
					</a>
					<p class="download-meta">v{version.version} · macOS Tahoe+ · Open Source</p>
				</div>

				<div class="hero-trust">
					<span>
						<svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
						100% Local
					</span>
					<span>
						<svg viewBox="0 0 24 24"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/></svg>
						Nothing Stored but Text
					</span>
					<span>
						<svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
						Open Source
					</span>
					<span>
						<svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
						macOS Tahoe+
					</span>
				</div>

				<div class="hero-divider"></div>

				<div class="hero-links">
					<a href="https://github.com/usererun/rerun" aria-label="GitHub">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
					</a>
					<a href="https://x.com/UseRerun" aria-label="X">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
					</a>
				</div>
			</div>
		</section>

		<script is:inline>
			document.getElementById('waitlist-form').addEventListener('submit', async (e) => {
				e.preventDefault();

				const form = e.target;
				const btn = form.querySelector('button');
				const message = document.getElementById('message');
				const original = btn.textContent;

				btn.disabled = true;
				btn.textContent = 'Joining...';
				message.textContent = '';

				try {
					const response = await fetch('/api/waitlist', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ email: form.email.value })
					});

					if (!response.ok) {
						const data = await response.json();
						throw new Error(data.error || 'Signup failed');
					}
					message.textContent = "You're on the list!";
					message.style.color = '#4ade80';
					form.reset();
				} catch (error) {
					message.textContent = error.message || 'Something went wrong. Try again.';
					message.style.color = '#f87171';
				} finally {
					btn.disabled = false;
					btn.textContent = original;
				}
			});
		</script>
	</body>
</html>

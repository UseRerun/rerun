---

---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>Rerun — Screen memory for your Mac</title>
		<meta name="description" content="Rerun captures text from your screen and makes everything searchable. Local. Private. Open source." />

		<meta property="og:title" content="Rerun — Screen memory for your Mac" />
		<meta property="og:description" content="Rerun captures text from your screen and makes everything searchable. Local. Private. Open source." />
		<meta property="og:type" content="website" />

		<style>
			* { margin: 0; padding: 0; box-sizing: border-box; }

			body {
				font-family: -apple-system, BlinkMacSystemFont, "SF Pro", "Segoe UI", system-ui, sans-serif;
				background: #09090b;
				color: #fafafa;
				min-height: 100vh;
				display: flex;
				align-items: center;
				justify-content: center;
			}

			.container {
				max-width: 640px;
				padding: 2rem;
				text-align: center;
			}

			h1 {
				font-size: 3rem;
				font-weight: 700;
				letter-spacing: -0.03em;
				margin-bottom: 1rem;
			}

			.tagline {
				font-size: 1.25rem;
				color: #a1a1aa;
				line-height: 1.6;
				margin-bottom: 2.5rem;
			}

			.pills {
				display: flex;
				gap: 0.5rem;
				justify-content: center;
				margin-bottom: 3rem;
				flex-wrap: wrap;
			}

			.pill {
				font-size: 0.8rem;
				padding: 0.35rem 0.75rem;
				border-radius: 100px;
				border: 1px solid #27272a;
				color: #a1a1aa;
			}

			.waitlist-section {
				margin-bottom: 2rem;
			}

			.waitlist-section p {
				font-size: 0.95rem;
				color: #71717a;
				margin-bottom: 1rem;
			}

			.waitlist-btn {
				display: inline-block;
				padding: 0.75rem 2rem;
				background: #fafafa;
				color: #09090b;
				font-size: 1rem;
				font-weight: 600;
				border-radius: 8px;
				text-decoration: none;
				transition: opacity 0.15s;
			}

			.waitlist-btn:hover {
				opacity: 0.9;
			}

			.links {
				display: flex;
				gap: 1.5rem;
				justify-content: center;
				margin-top: 2rem;
			}

			.links a {
				color: #71717a;
				font-size: 0.85rem;
				text-decoration: none;
			}

			.links a:hover {
				color: #fafafa;
			}
		</style>
	</head>
	<body>
		<div class="container">
			<h1>Rerun</h1>
			<p class="tagline">
				Screen memory for your Mac.<br />
				Find anything you've ever seen.
			</p>

			<div class="pills">
				<span class="pill">100% local</span>
				<span class="pill">No screenshots stored</span>
				<span class="pill">Open source</span>
				<span class="pill">Agent-friendly</span>
			</div>

			<div class="waitlist-section">
				<p>Early development. Join the waitlist for first access.</p>
				<a href="https://waitlister.me/waitlists/rerun" class="waitlist-btn">Join the Waitlist</a>
			</div>

			<div class="links">
				<a href="https://github.com/usererun/rerun">GitHub</a>
				<a href="https://x.com/Shpigford">Follow updates</a>
			</div>
		</div>
	</body>
</html>
